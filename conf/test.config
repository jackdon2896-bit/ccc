/*
    Test profile — lightweight local run with tiny synthetic data
*/
params {
    spatial_h5    = "${projectDir}/test_data/test_spatial.h5ad"
    spatial_image = "${projectDir}/test_data/test_image.tif"
    sra_accessions = "SRR6470906"
    outdir        = "/tmp/ccc_test_out"

    min_genes  = 10
    min_cells  = 1
    max_genes  = 10000
    mt_percent_max = 100

    n_top_genes   = 200
    n_pcs         = 10
    n_epochs      = 5
    hidden_dim    = 32
    clustering_resolution = 0.5
    n_neighbors   = 5
    ccc_distance_threshold = 9999
}

process {
    cpus   = 1
    memory = '4 GB'
    time   = '30 min'
}
