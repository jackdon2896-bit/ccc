/*
========================================================================================
    Golden Standard Pipeline — nextflow.config
    Spatial + scRNA-seq + ML + Cell-Cell Communication
========================================================================================
*/

// ── Manifest ──────────────────────────────────────────────────────────────────
manifest {
    name            = 'golden-std-spatial-scrna-ml-ccc'
    author          = 'jackdon2896-bit'
    homePage        = 'https://github.com/jackdon2896-bit/ccc'
    description     = 'Spatial transcriptomics + scRNA-seq + Machine Learning + CCC pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '2.0.0'
    defaultBranch   = 'main'
}

// ── Wave (container provisioning) ─────────────────────────────────────────────
wave {
    enabled  = true
    strategy = ['container']
}

// ── Default parameters ─────────────────────────────────────────────────────────
params {
    // ── Spatial inputs ──
    spatial_h5    = "s3://dinesh-rdr-omics-2026/cell-com-input/mouse_brain.h5"
    spatial_image = "s3://dinesh-rdr-omics-2026/cell-com-input/mouse_brain.tif"

    // ── scRNA-seq SRA accessions ──
    sra_accessions = "SRR6470906,SRR6470907,SRR6470908,SRR6470910,SRR6470911,SRR6470912,SRR6470915,SRR6470916,SRR6470917,SRR6470923,SRR6470924,SRR6470925"

    // ── Output ──
    outdir = "s3://dinesh-rdr-omics-2026/results/golden_standard"

    // ── QC thresholds ──
    min_genes      = 200
    min_cells      = 3
    max_genes      = 5000
    mt_percent_max = 20

    // ── Analysis settings ──
    n_top_genes            = 2000
    n_pcs                  = 50
    clustering_resolution  = 0.5
    n_neighbors            = 15

    // ── ML settings ──
    n_epochs      = 200
    learning_rate = 0.01
    hidden_dim    = 128

    // ── CCC settings ──
    ccc_distance_threshold = 500

    // ── Reference ──
    genome = "mm10"

    // ── Legacy compat ──
    scrna_data = null
    spatial_data = null
    output_dir = null
    mode = 'full'
    spot_diameter = 100
    resolution = 0.5
    max_cpus = 8
    max_memory = '64.GB'
    max_time = '6.h'
    help = false
}

// ── Process defaults ───────────────────────────────────────────────────────────
process {
    container    = 'community.wave.seqera.io/library/scanpy_squidpy_cellpose_torch:latest'
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries   = 2

    withLabel: process_low {
        cpus   = 2
        memory = '8 GB'
        time   = '2 h'
    }
    withLabel: process_medium {
        cpus   = 4
        memory = '16 GB'
        time   = '4 h'
    }
    withLabel: process_high {
        cpus   = 8
        memory = '32 GB'
        time   = '8 h'
    }

    withName: 'SRA_DOWNLOAD'       { label = 'process_medium' }
    withName: 'PREPROCESS_SPATIAL' { label = 'process_medium' }
    withName: 'PREPROCESS_SCRNA'   { label = 'process_medium' }
    withName: 'CELLPOSE_SEGMENT'   { label = 'process_high'   }
    withName: 'SCRNA_ANALYSIS'     { label = 'process_high'   }
    withName: 'SPATIAL_ANALYSIS'   { label = 'process_high'   }
    withName: 'ML_ANALYSIS'        { label = 'process_high'   }
    withName: 'GNN_ANALYSIS'       { label = 'process_high'   }
    withName: 'TRAJECTORY_INFERENCE' { label = 'process_high' }
    withName: 'CCC_CELLCHAT'       { label = 'process_high'   }
    withName: 'CCC_LIANA'          { label = 'process_high'   }
    withName: 'CCC_COMMOT'         { label = 'process_high'   }
    withName: 'FINAL_INTEGRATION'  { label = 'process_high'   }
    withName: 'GENERATE_REPORT'    { label = 'process_medium' }
}

// ── Profiles ───────────────────────────────────────────────────────────────────
profiles {
    standard {
        process.executor = 'local'
        docker.enabled   = true
    }
    docker {
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
        singularity.enabled = false
    }
    singularity {
        singularity.enabled  = true
        singularity.autoMounts = true
        docker.enabled       = false
    }
    aws {
        process.executor = 'awsbatch'
        aws.region       = 'us-east-1'
        fusion.enabled   = true
        wave.enabled     = true
    }
    seqera {
        process.executor = 'awsbatch'
        fusion.enabled   = true
        wave.enabled     = true
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// ── Reports ────────────────────────────────────────────────────────────────────
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt";     overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.html";      overwrite = true }

// ── Resource limits ────────────────────────────────────────────────────────────
resourceLimits {
    cpus   = 8
    memory = '64 GB'
    time   = '8 h'
}
