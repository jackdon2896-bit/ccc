/*
========================================================================================
    Pipeline Configuration
========================================================================================
*/

// Manifest
manifest {
    name            = 'Cell-Cell Communication Spatial Pipeline'
    author          = 'Seqera AI'
    homePage        = 'https://github.com/jackdon2896-bit/ccc'
    description     = 'Advanced spatial transcriptomics with cell communication and ML'
    mainScript      = 'main.nf'
    nextflowVersion = '>=25.04.0'
    version         = '1.0.0'
}

// Default parameters
params {
    // Input
    tiff            = null
    h5              = null
    sra_ids         = null
    scrna_ref       = null
    
    // Output
    outdir          = "results"
    
    // QC thresholds
    min_genes       = 200
    min_cells       = 3
    max_mito_pct    = 20
    
    // Cellpose settings
    cellpose_model  = 'cyto2'
    cell_diameter   = 30
    
    // Clustering
    n_neighbors     = 15
    resolution      = 0.8
    
    // Communication
    comm_method     = 'liana'  // or 'commot'
    min_spots       = 5
    
    // ML classification
    ml_model        = 'random_forest'
    cv_folds        = 5
    
    // Resources
    max_cpus        = 16
    max_memory      = '64.GB'
    max_time        = '24.h'
}

// Process configuration
process {
    // Default container
    container = 'community.wave.seqera.io/library/anndata_cellphonedb_cellpose_celltypist_pruned:f40b275367e7e126'
    
    // Error strategy
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 3
    
    // Resource labels
    withLabel: process_low {
        cpus   = { 2 * task.attempt }
        memory = { 4.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }
    
    withLabel: process_medium {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 6.h * task.attempt }
    }
    
    withLabel: process_high {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 12.h * task.attempt }
    }
    
    withLabel: process_ml {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }
}

// Profiles
profiles {
    
    standard {
        process.executor = 'local'
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    
    aws {
        process.executor = 'awsbatch'
        process.queue = 'nextflow-queue'
        workDir = 's3://your-bucket/work'
        aws.region = 'us-east-1'
        aws.batch.cliPath = '/home/ec2-user/miniconda/bin/aws'
    }
    
    seqera {
        process.executor = 'awsbatch'
        workDir = 's3://your-bucket/work'
        aws.region = 'us-east-1'
        wave.enabled = true
        fusion.enabled = true
    }
    
    test {
        params.tiff = 'https://cf.10xgenomics.com/samples/spatial-exp/2.0.0/Visium_Mouse_Olfactory_Bulb/Visium_Mouse_Olfactory_Bulb_image.tif'
        params.h5 = 'https://cf.10xgenomics.com/samples/spatial-exp/2.0.0/Visium_Mouse_Olfactory_Bulb/Visium_Mouse_Olfactory_Bulb_filtered_feature_bc_matrix.h5'
        params.outdir = 'test_results'
    }
}

// Timeline, report, trace
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.svg"
}
