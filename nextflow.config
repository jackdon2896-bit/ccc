/*
========================================================================================
    Nextflow Configuration for Seqera Cloud
========================================================================================
    Optimized for Community Showcase AWS Batch
    Production-ready settings
========================================================================================
*/

// Manifest
manifest {
    name = 'spatial-scrna-integration'
    author = 'Academic Researcher'
    description = 'Spatial transcriptomics + scRNA-seq integration pipeline'
    version = '1.0.0'
    nextflowVersion = '>=23.04.0'
    defaultBranch = 'main'
}

// Default parameters
params {
    // Input/Output
    scrna_data = null
    spatial_data = null
    output_dir = null
    
    // Analysis mode
    mode = 'full'
    
    // Integration parameters
    n_top_genes = 2000
    n_pcs = 50
    resolution = 0.5
    
    // Spatial parameters
    spot_diameter = 100
    n_neighbors = 15
    
    // Resource limits
    max_cpus = 8
    max_memory = '64.GB'
    max_time = '6.h'
    
    // Help message
    help = false
}

// Process defaults
process {
    // Error handling
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 2
    maxErrors = '-1'
    
    // Resource defaults
    cpus = 2
    memory = '8.GB'
    time = '2.h'
    
    // Container settings
    container = 'quay.io/biocontainers/scanpy:1.9.3--pyhdfd78af_0'
    
    // Publish settings
    publishDir = [
        path: { "${params.output_dir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        overwrite: true,
        saveAs: { filename -> filename }
    ]
    
    // AWS Batch specific settings
    withLabel: 'process_low' {
        cpus = 2
        memory = '8.GB'
        time = '2.h'
    }
    
    withLabel: 'process_medium' {
        cpus = 4
        memory = '32.GB'
        time = '3.h'
    }
    
    withLabel: 'process_high' {
        cpus = 8
        memory = '64.GB'
        time = '4.h'
    }
}

// Execution profiles
profiles {
    // Standard profile (local testing)
    standard {
        process.executor = 'local'
        process.container = 'quay.io/biocontainers/scanpy:1.9.3--pyhdfd78af_0'
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    // Seqera Cloud Community Showcase profile
    seqera_showcase {
        process.executor = 'awsbatch'
        process.container = 'quay.io/biocontainers/scanpy:1.9.3--pyhdfd78af_0'
        
        aws {
            region = 'us-east-1'
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
                maxParallelTransfers = 4
                maxTransferAttempts = 3
            }
        }
        
        // Optimize for AWS Batch
        process {
            errorStrategy = 'retry'
            maxRetries = 3
            
            // Use spot instances for cost savings
            queue = 'seqera-showcase-queue'
        }
        
        workDir = 's3://seqera-showcase-workdir'
    }
    
    // AWS Batch profile (for your own AWS account)
    awsbatch {
        process.executor = 'awsbatch'
        process.container = 'quay.io/biocontainers/scanpy:1.9.3--pyhdfd78af_0'
        
        aws {
            region = 'us-east-1'
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
                maxParallelTransfers = 4
                maxTransferAttempts = 3
            }
        }
        
        process {
            errorStrategy = 'retry'
            maxRetries = 3
        }
        
        // Set your work directory
        workDir = 's3://YOUR-BUCKET/work'
    }
    
    // Docker profile (local with Docker)
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        singularity.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }
    
    // Singularity profile (HPC)
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        podman.enabled = false
        shifter.enabled = false
        charliecloud.enabled = false
    }
}

// Execution report settings
timeline {
    enabled = true
    file = "${params.output_dir}/reports/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.output_dir}/reports/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.output_dir}/reports/trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

dag {
    enabled = true
    file = "${params.output_dir}/reports/dag.html"
    overwrite = true
}

// Notification settings
notification {
    enabled = false
    to = 'your-email@example.com'
}

// Cleanup settings
cleanup = false

// Singularity cache directory
singularity.cacheDir = "$HOME/.singularity/cache"

// Conda settings (if needed)
conda {
    enabled = false
    cacheDir = "$HOME/.conda/envs"
    createTimeout = '1h'
}

// Tower/Seqera Platform settings
tower {
    enabled = true
    accessToken = null  // Set via environment variable or command line
}

// Resource monitoring
resourceLimits {
    cpus = params.max_cpus
    memory = params.max_memory
    time = params.max_time
}
